{
  "name": "yahooquery_lakehouse",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },

  "containerEnv": {
    "MLFLOW_TRACKING_URI": "http://host.docker.internal:5001",
    "MLFLOW_S3_ENDPOINT_URL": "http://host.docker.internal:9000",
    "MLFLOW_EXPERIMENT_NAME": "stock_close_training",
    "MLFLOW_HTTP_REQUEST_TIMEOUT": "60",
    "MLFLOW_HTTP_REQUEST_MAX_RETRIES": "1",
    "MLFLOW_HTTP_REQUEST_BACKOFF_FACTOR": "1",
    "AWS_ACCESS_KEY_ID": "admin",
    "AWS_SECRET_ACCESS_KEY": "admin1234",
    "AWS_ALLOW_HTTP": "true",
    "AWS_VIRTUAL_HOSTED_STYLE_REQUEST": "false",
    "DELTA_LAKE_S3_ENDPOINT_URL": "http://host.docker.internal:9000",
    "DELTA_LAKE_S3_ACCESS_KEY": "admin",
    "DELTA_LAKE_S3_SECRET_KEY": "admin1234",
    "DELTA_LAKE_S3_BUCKET": "delta-lake-bucket",
    "DBT_PROJECT_DIR": "/opt/dbt_project",
    "DBT_PROFILES_DIR": "/opt/dbt_project",
    "DBT_MANIFEST_PATH": "/opt/dbt_project/target/manifest.json",
    "DBT_DUCKDB_PATH": "/workspaces/yahooquery_lakehouse_revamp/database/duckdb/dataops_mlops.duckdb",
    "PECNETFRAMEWORK_PATH": "/opt/pecnetframework",
    "MODEL_TRAINING_DATA_SOURCE": "feast_online",
    "FEATURE_REPO_DIR": "/opt/feature_repo",
    "TIMESCALE_HOST": "host.docker.internal",
    "TIMESCALE_PORT": "5432",
    "TIMESCALE_DB": "dataops",
    "TIMESCALE_USER": "dataops",
    "TIMESCALE_PASSWORD": "dataops",
    "TIMESCALE_WRITE_BATCH_SIZE": "250",
    "DAGSTER_HOME": "/opt/dagster_home",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONPATH": "/opt/dataops_app/src:/opt/kedro_project/src",
    "PIP_NO_CACHE_DIR": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "OMP_NUM_THREADS": "10",
    "OPENBLAS_NUM_THREADS": "10",
    "MKL_NUM_THREADS": "10",
    "NUMEXPR_NUM_THREADS": "10",
    "POLARS_MAX_THREADS": "10",
    "KEDRO_PROJECT_DIR": "/opt/kedro_project",
    "KEDRO_LOGGING_CONFIG": "/opt/kedro_project/conf/base/logging.yml"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "innoverio.vscode-dbt-power-user"
      ]
    }
  },

  "forwardPorts": [3000, 4141, 4213],

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "postCreateCommand": "sh .devcontainer/post_create.sh",

  "mounts": [
    "source=yahooquery-lakehouse-venv,target=/workspaces/yahooquery_lakehouse_revamp/.venv,type=volume",
    "source=yahooquery-lakehouse-dagster-home,target=/opt/dagster_home,type=volume",
    "source=yahooquery-lakehouse-dbt-runtime,target=/opt/dbt_project,type=volume",
    "source=yahooquery-lakehouse-feature-repo,target=/opt/feature_repo,type=volume",
    "source=yahooquery-lakehouse-app-runtime,target=/opt/dataops_app,type=volume",
    "source=yahooquery-lakehouse-kedro-runtime,target=/opt/kedro_project,type=volume",
    "source=yahooquery-lakehouse-pecnet-runtime,target=/opt/pecnetframework,type=volume"
  ]
}
