AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=admin1234
AWS_REGION=us-east-1
AWS_ALLOW_HTTP=true
AWS_VIRTUAL_HOSTED_STYLE_REQUEST=false

S3_ENDPOINT=http://host.docker.internal:9000
DELTA_LAKE_S3_ENDPOINT_URL=http://host.docker.internal:9000
DELTA_LAKE_S3_ACCESS_KEY=admin
DELTA_LAKE_S3_SECRET_KEY=admin1234
DELTA_LAKE_S3_BUCKET=delta-lake-bucket

DBT_DUCKDB_PATH=/workspaces/yahooquery_lakehouse_revamp/database/duckdb/dataops_mlops.duckdb
ui_local_port=4213

MLFLOW_TRACKING_URI=http://host.docker.internal:5001
MLFLOW_S3_ENDPOINT_URL=http://host.docker.internal:9000
MLFLOW_EXPERIMENT_NAME=stock_close_training
MLFLOW_HTTP_REQUEST_TIMEOUT=60
MLFLOW_HTTP_REQUEST_MAX_RETRIES=1
MLFLOW_HTTP_REQUEST_BACKOFF_FACTOR=1

WANDB_API_KEY=replace_with_your_wandb_cloud_api_key

FEAST_S3_ENDPOINT_URL=http://host.docker.internal:9000
FEAST_S3_ACCESS_KEY=admin
FEAST_S3_SECRET_KEY=admin1234
FEAST_S3_BUCKET=feast-bucket
FEAST_REDIS_HOST=host.docker.internal
FEAST_REDIS_PORT=6379
MODEL_TRAINING_DATA_SOURCE=feast_online

TIMESCALE_HOST=host.docker.internal
TIMESCALE_PORT=5432
TIMESCALE_DB=dataops
TIMESCALE_USER=dataops
TIMESCALE_PASSWORD=dataops

KEDRO_PROJECT_DIR=/opt/kedro_project
KEDRO_LOGGING_CONFIG=/opt/kedro_project/conf/base/logging.yml
